# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── WhatsApp Support ─────────────────────────────────────────────────────────
# Phone number with country code, no + or spaces
NEXT_PUBLIC_WHATSAPP_NUMBER=260971234567

# ─── App Config ───────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Auth Mode ────────────────────────────────────────────────────────────────
# Set to "true" to bypass Supabase and use mock data (development only)
# Remove or set to "false" in production
NEXT_PUBLIC_MOCK_AUTH=false
